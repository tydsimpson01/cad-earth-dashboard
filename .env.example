# Riot Games API. Server-only: never expose this value with NEXT_PUBLIC_.
RIOT_API_KEY=
# Account-v1 and Match-v5 routing region for this roster.
RIOT_ROUTING_REGION=americas
# Small read-only sample size used by admin Riot status checks.
RIOT_RECENT_MATCH_COUNT=3
# Supabase public client configuration. Safe for browser use.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
